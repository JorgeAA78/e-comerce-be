{
  "name": "e-commerce-backend",
  "version": "1.0.0",
  "description": "Backend de e-commerce con TypeScript, Express, Firebase, Algolia y MercadoPago",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "npx ts-node src/seeds/seed-products.ts",
    "test": "node --loader=esbuild-node-loader node_modules/.bin/ava"
  },
  "keywords": [
    "ecommerce",
    "typescript",
    "express",
    "firebase",
    "mercadopago"
  ],
  "author": "Jorge Altamirano",
  "license": "ISC",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "algoliasearch": "^4.24.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "firebase-admin": "^13.7.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.0.15",
    "random-seed": "^0.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/random-seed": "^0.3.5",
    "@types/supertest": "^7.2.0",
    "ava": "^6.1.2",
    "esbuild": "^0.20.1",
    "esbuild-node-loader": "^0.8.0",
    "nodemon": "^3.0.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "ava": {
    "nodeArguments": [
      "--loader=esbuild-node-loader",
      "--experimental-specifier-resolution=node"
    ],
    "environmentVariables": {
      "TESTING": "true"
    },
    "extensions": {
      "ts": "module"
    }
  }
}
