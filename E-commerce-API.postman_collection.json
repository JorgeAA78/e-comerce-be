{
  "info": {
    "name": "E-commerce Backend API",
    "_postman_id": "ecommerce-backend-api-v1",
    "description": "Colección completa de endpoints del E-commerce Backend — TypeScript + Express + Firebase + Algolia + MercadoPago",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "POST /auth — Solicitar código",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tu@email.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth",
              "host": ["{{baseUrl}}"],
              "path": ["auth"]
            }
          }
        },
        {
          "name": "POST /auth/token — Validar código → JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token guardado:', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tu@email.com\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "token"]
            }
          }
        }
      ]
    },
    {
      "name": "👤 Usuario (/me)",
      "item": [
        {
          "name": "GET /me — Info del usuario",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/me",
              "host": ["{{baseUrl}}"],
              "path": ["me"]
            }
          }
        },
        {
          "name": "PATCH /me — Actualizar datos",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jorge Altamirano\",\n  \"phone\": \"+5491112345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/me",
              "host": ["{{baseUrl}}"],
              "path": ["me"]
            }
          }
        },
        {
          "name": "PATCH /me/address — Actualizar dirección",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"street\": \"Av. Corrientes 1234\",\n  \"city\": \"Buenos Aires\",\n  \"state\": \"CABA\",\n  \"zip\": \"1043\",\n  \"country\": \"Argentina\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/me/address",
              "host": ["{{baseUrl}}"],
              "path": ["me", "address"]
            }
          }
        }
      ]
    },
    {
      "name": "🛍️ Productos",
      "item": [
        {
          "name": "GET /search — Buscar productos (Algolia)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/search?q=remera&offset=0&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["search"],
              "query": [
                {"key": "q", "value": "remera"},
                {"key": "offset", "value": "0"},
                {"key": "limit", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "GET /products/:id — Detalle de producto",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "📦 Órdenes",
      "item": [
        {
          "name": "POST /order — Crear orden + link MP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.orderId) {",
                  "  pm.collectionVariables.set('orderId', json.orderId);",
                  "  console.log('Order ID:', json.orderId);",
                  "  console.log('Init Point:', json.initPoint);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/order?productId={{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["order"],
              "query": [{"key": "productId", "value": "{{productId}}"}]
            }
          }
        },
        {
          "name": "GET /me/orders — Mis órdenes",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/me/orders",
              "host": ["{{baseUrl}}"],
              "path": ["me", "orders"]
            }
          }
        },
        {
          "name": "GET /order/:orderId — Detalle de orden",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/order/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["order", "{{orderId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "💳 Webhook IPN",
      "item": [
        {
          "name": "POST /ipn/mercadopago — Webhook (simular)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"payment\",\n  \"data\": {\n    \"id\": \"TU_PAYMENT_ID_AQUI\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/ipn/mercadopago",
              "host": ["{{baseUrl}}"],
              "path": ["ipn", "mercadopago"]
            }
          }
        }
      ]
    },
    {
      "name": "🔍 Health Check",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    }
  ]
}
